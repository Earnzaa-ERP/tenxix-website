# ============================================
# TENXIX.com — clean URLs
# ============================================
# Goals:
#   1. /about.html → 301 redirect to /about  (canonical, SEO-friendly)
#   2. /about      → silently serves about.html   (no extension needed)
#   3. /index.html → 301 redirect to /         (canonical home)
#   4. /products   → serves products.html (NOT the products/ folder listing)
#   5. /products/wellness-trainer → serves products/wellness-trainer.html
#   6. Directory listings disabled entirely
# ============================================

Options -Indexes +FollowSymLinks -MultiViews

# Default index file when a folder is visited
DirectoryIndex index.html

RewriteEngine On

# ── 1. Trailing-slash strip when an equivalent .html exists.
#       e.g. /products/  →  /products   (then rule 4 serves products.html)
#       Stops mod_dir from auto-appending the slash that would cause a loop.
RewriteCond %{DOCUMENT_ROOT}/$1.html -f
RewriteRule ^(.+)/$ /$1 [R=301,L,NE]

# ── 2. /folder/index.html  →  /folder/    (301)
RewriteCond %{THE_REQUEST} \s/+(.+/)?index\.html[\s?] [NC]
RewriteRule ^(.+/)?index\.html$ /%1 [R=301,L,NE]

# ── 3. /anything.html  →  /anything       (301)
RewriteCond %{THE_REQUEST} \s/+(.+?)\.html[\s?] [NC]
RewriteRule ^ /%1 [R=301,L,NE]

# ── 4. /anything  →  /anything.html       (silent rewrite, only if the .html exists)
#       NOTE: we deliberately do NOT skip when a directory of the same name exists
#       (so /products serves products.html even though /products/ folder exists).
#       The -f check on $1.html still guarantees we only rewrite when the file
#       actually exists, so /assets stays a directory and serves nothing
#       (with -Indexes giving a clean 403 instead of a listing).
RewriteCond %{REQUEST_FILENAME} !-f
RewriteCond %{DOCUMENT_ROOT}/$1.html -f
RewriteRule ^(.+?)/?$ $1.html [L]

# ── (Optional) Gzip compression for faster page loads
<IfModule mod_deflate.c>
  AddOutputFilterByType DEFLATE text/html text/plain text/xml text/css text/javascript application/javascript application/json image/svg+xml
</IfModule>

# ── (Optional) Long cache for static assets
<IfModule mod_expires.c>
  ExpiresActive On
  ExpiresByType text/css                "access plus 30 days"
  ExpiresByType application/javascript  "access plus 30 days"
  ExpiresByType image/png               "access plus 60 days"
  ExpiresByType image/jpeg              "access plus 60 days"
  ExpiresByType image/jpg               "access plus 60 days"
  ExpiresByType image/svg+xml           "access plus 60 days"
  ExpiresByType image/webp              "access plus 60 days"
  ExpiresByType font/woff               "access plus 60 days"
  ExpiresByType font/woff2              "access plus 60 days"
</IfModule>

# ── Security headers (defence in depth)
<IfModule mod_headers.c>
  Header set X-Content-Type-Options "nosniff"
  Header set X-Frame-Options "SAMEORIGIN"
  Header set Referrer-Policy "strict-origin-when-cross-origin"
</IfModule>
